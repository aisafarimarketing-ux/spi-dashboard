# SPI environment variables.
#
# Copy to `.env.local` (gitignored) and fill in. Never commit real values.

# ── Database ────────────────────────────────────────────────────────────────
# Supabase Postgres connection string.
#   Supabase dashboard → Project → Settings → Database → Connection string
#   → URI (the "direct" one on port 5432, NOT the pooler).
# Looks like:
#   postgresql://postgres:PASSWORD@db.PROJECT-REF.supabase.co:5432/postgres
#
# Why direct (5432) and not pooled (6543): Prisma migrations need stable
# advisory locks that the transaction-mode pooler doesn't allow. We're
# hosting on Railway containers, so the direct connection works for
# runtime queries too. If we ever switch to a serverless runtime, add a
# DIRECT_URL for migrations and use the pooled URL for app traffic.
DATABASE_URL=

# ── Clerk (auth + organizations) ────────────────────────────────────────────
# From Clerk dashboard → API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Where Clerk redirects on sign-in / sign-up — leave defaults unless you've
# customised the routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Anthropic (Tell-SPI parser) — added in Unit 1.9 ─────────────────────────
# ANTHROPIC_API_KEY=
